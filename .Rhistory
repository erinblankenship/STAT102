samples$mean[i]<-mean(data)
}
ggplot(samples, aes(mean)) + geom_histogram(fill='lightgray',col='black')
gammapdf<-seq(0,1,0.001)
alpha<-0.05
beta<-0.01
plot(gammapdf, dgamma(gammapdf, shape=alpha, scale=1/beta),type='h',xlim=c(0,1))
samples<-data.frame(sim=1:1000,mean=NA)
for(i in 1:1000){
data<-rgamma(4,shape=alpha,scale=1/beta)
samples$mean[i]<-mean(data)
}
ggplot(samples, aes(mean)) + geom_histogram(fill='lightgray',col='black')
ggplot(samples, aes(mean)) +
geom_histogram(aes(y = ..density..), fill='lightgray', col='black') +
stat_function(fun = dnorm, args = list(mean=mean(samples$mean), sd=sd(samples$mean)))
rpois(6,12)
